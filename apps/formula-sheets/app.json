{
  "expo": {
    "name": "JEE Formula Sheets - RealSem",
    "slug": "jee-formula-sheets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.realsem.jeeformulas"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A56DB"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.realsem.jeeformulas"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6090655991033622~8230787965"
        }
      ]
    ]
  }
}
